-    if (typeof value === 'string' && value.trim()) {
-      const trimmed = value.trim()
-      return trimmed.length > 80 ? `${trimmed.slice(0, 80)}…` : trimmed
-    }
-  } catch {
-    // Ignore malformed argument JSON.
-  }
-  return undefined
-}
